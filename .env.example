# API oficial da Calculadora de Tributos do Consumo
TRIBUTOS_TARGET_BASE=https://consumo.tributos.gov.br:60442/servico/calcular-tributos-consumo/api
TRIBUTOS_TIMEOUT_MS=30000

# API CNAE IBGE usa endpoint público e normalmente não precisa de variável.
IBGE_TIMEOUT_MS=20000

# Restrinja para seu domínio em produção, se desejar.
# Exemplo: https://app.corytax.com.br
CORYTAX_ALLOW_ORIGIN=*

# Opcional: URL do Google Apps Script/CRM/planilha para receber leads.
# Não coloque esta URL no front-end; configure nas variáveis de ambiente da Vercel.
APPS_SCRIPT_URL=
LEAD_TIMEOUT_MS=20000

# Claude API (Anthropic)
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# Modelo padrão (opcional). Opções válidas maio 2026:
#   claude-opus-4-6      → mais capaz
#   claude-sonnet-4-6    → recomendado (padrão)
#   claude-haiku-4-5     → mais rápido/barato
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024
CLAUDE_TIMEOUT_MS=60000
