{
  "version": 2,
  "public": true,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/ibge/:path*", "destination": "/api/ibge/[...path]" },
    { "source": "/api/tributos/:path*", "destination": "/api/tributos/[...path]" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
